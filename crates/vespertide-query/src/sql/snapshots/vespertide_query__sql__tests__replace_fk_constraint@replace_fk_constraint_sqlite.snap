CREATE TABLE "posts_temp" ( "id" integer, "user_id" integer, PRIMARY KEY ("id"), FOREIGN KEY ("user_id") REFERENCES "users" ("id") ON DELETE CASCADE );
INSERT INTO "posts_temp" ("id", "user_id") SELECT "id", "user_id" FROM "posts";
DROP TABLE "posts";
ALTER TABLE "posts_temp" RENAME TO "posts"
