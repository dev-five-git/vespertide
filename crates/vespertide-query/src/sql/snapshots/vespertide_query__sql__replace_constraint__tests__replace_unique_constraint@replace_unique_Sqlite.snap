---
source: crates/vespertide-query/src/sql/replace_constraint.rs
description: replace unique constraint for Sqlite
---
CREATE TABLE "users_temp" ( "id" integer NOT NULL, "email" text NOT NULL, PRIMARY KEY ("id") );
INSERT INTO "users_temp" ("id", "email") SELECT "id", "email" FROM "users";
DROP TABLE "users";
ALTER TABLE "users_temp" RENAME TO "users";
CREATE UNIQUE INDEX "uq_users__uq_email" ON "users" ("email")
